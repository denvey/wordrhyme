{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": [
        "NODE_ENV"
    ],
    "globalPassThroughEnv": [
        "NODE_ENV"
    ],
    "ui": "stream",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^build"
            ]
        },
        "type-check": {
            "dependsOn": [
                "^build"
            ]
        },
        "test": {
            "dependsOn": [
                "build"
            ]
        },
        "clean": {
            "cache": false
        }
    }
}