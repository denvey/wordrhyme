# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wordrhyme

# Redis (required for queue system)
REDIS_URL=redis://localhost:6379

# Queue System
# WORKER_MODE=standalone  # Set to 'standalone' to run worker as separate process

# CORS (comma-separated origins for production)
CORS_ORIGINS=

# Plugin
PLUGIN_DIR=../../plugins
PLUGIN_MODE=development

# Safe Mode (skip non-core plugins)
WORDRHYME_SAFE_MODE=false
