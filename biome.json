{
    "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true,
        "defaultBranch": "main"
    },
    "files": {
        "ignore": [
            "node_modules",
            "dist",
            "out",
            "build",
            "public",
            "tsconfig.*",
            "*.gen.*"
        ],
        "include": [
            "**/*.js",
            "**/*.jsx",
            "**/*.ts",
            "**/*.tsx",
            "**/*.scss",
            "**/*.css",
            "**/*.json",
            "**/*.html"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "ignore": [
            "node_modules",
            "dist",
            "out",
            "build",
            "public",
            "*.gen.*"
        ]
    },
    "organizeImports": {
        "enabled": true
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noConsoleLog": "warn",
                "noEmptyInterface": "off",
                "noArrayIndexKey": "warn"
            },
            "correctness": {
                "noUnusedVariables": "warn",
                "useExhaustiveDependencies": "warn"
            },
            "style": {
                "noNonNullAssertion": "off",
                "useImportType": "warn"
            },
            "performance": {
                "noDelete": "off"
            }
        }
    },
    "overrides": [
        {
            "include": [
                "apps/server/**"
            ],
            "linter": {
                "rules": {
                    "style": {
                        "useImportType": "off"
                    }
                }
            },
            "javascript": {
                "parser": {
                    "unsafeParameterDecoratorsEnabled": true
                }
            }
        }
    ]
}