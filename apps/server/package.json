{
    "name": "@wordrhyme/server",
    "version": "0.1.0-alpha.1",
    "private": true,
    "type": "module",
    "exports": {
        "./trpc/router": "./src/trpc/router.ts",
        "./plugins/capabilities/data": "./src/plugins/capabilities/data.capability.ts",
        "./db": "./src/db/index.ts"
    },
    "scripts": {
        "build": "nest build",
        "dev": "nest build && (nest build --watch &) && node --watch dist/main.js",
        "start": "node dist/main.js",
        "start:prod": "node dist/main.js",
        "lint": "eslint \"src/**/*.ts\"",
        "type-check": "tsc --noEmit",
        "type-check:src": "tsc --noEmit -p tsconfig.src.json",
        "clean": "rm -rf dist",
        "test": "pnpm run test:unit",
        "test:unit": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:all": "pnpm run test:unit && pnpm run test:integration",
        "test:coverage": "vitest run --coverage",
        "test:permission": "vitest run src/__tests__/permission/",
        "test:permission:watch": "vitest src/__tests__/permission/",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "node --import tsx scripts/db/migrate.ts",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:seed": "pnpm --filter @wordrhyme/db build && node --import tsx src/db/seed.ts",
        "seed:auth": "tsx src/db/seed-auth.ts",
        "seed:roles": "tsx src/db/seed/seed-roles-backfill.ts",
        "seed:geo": "pnpm --filter @wordrhyme/db build && node --import tsx src/db/seed/seed-geo.ts",
        "seed:admin-permissions": "tsx src/db/seed/seed-admin-permissions.ts",
        "seed:test-accounts": "tsx src/db/seed/seed-test-accounts.ts",
        "seed:accounts": "tsx src/db/seed/seed-accounts.ts",
        "script:reset-dev": "tsx scripts/dev/reset-dev-database.ts",
        "script:seed-initial": "tsx scripts/seed/seed-initial-data.ts",
        "script:setup-cross-tenant": "tsx scripts/setup/setup-cross-tenant-permissions.ts"
    },
    "dependencies": {
        "@better-auth/api-key": "^1.5.3",
        "@better-auth/drizzle-adapter": "^1.5.3",
        "@casl/ability": "^6.8.0",
        "@fastify/cors": "^9.0.1",
        "@fastify/multipart": "^9.4.0",
        "@fastify/static": "^8.3.0",
        "@nestjs/common": "^11.1.15",
        "@nestjs/core": "^11.1.15",
        "@nestjs/platform-fastify": "^11.1.15",
        "@nestjs/platform-socket.io": "^11.1.15",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/websockets": "^11.1.15",
        "@node-rs/argon2": "^2.0.2",
        "@thallesp/nestjs-better-auth": "^2.4.0",
        "@trpc/server": "^11.11.0",
        "@wordrhyme/auto-crud-server": "^1.0.2",
        "@wordrhyme/db": "workspace:*",
        "@wordrhyme/plugin": "workspace:*",
        "ajv": "^8.18.0",
        "ajv-formats": "^3.0.1",
        "better-auth": "^1.5.3",
        "bullmq": "^5.70.1",
        "cron-parser": "^5.5.0",
        "decimal.js": "^10.6.0",
        "dotenv": "^17.3.1",
        "drizzle-orm": "1.0.0-beta.14-a36c63d",
        "drizzle-zod": "1.0.0-beta.14-a36c63d",
        "glob": "^11.1.0",
        "ioredis": "^5.10.0",
        "postgres": "^3.4.8",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "stripe": "^20.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.16",
        "@swc/cli": "^0.5.2",
        "@swc/core": "^1.15.18",
        "@types/node": "^22.19.13",
        "@vitest/coverage-v8": "^4.0.18",
        "drizzle-kit": "1.0.0-beta.15-859cf75",
        "fast-check": "^4.3.0",
        "fastify": "^5.7.4",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "unplugin-swc": "^1.5.9",
        "vitest": "^4.0.18"
    }
}
