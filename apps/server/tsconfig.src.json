{
    "extends": "./tsconfig.json",
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "*.config.ts",
        "src/__tests__/**",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx",
        "src/**/*.integration.test.ts",
        "src/**/integration/**",
        "src/db/seed/**",
        "src/db/seeds/**",
        "src/db/seed-auth.ts",
        "src/db/seed.ts",
        "src/trpc/routers/user-admin.example.ts",
        "src/trpc/routers/articles.ts",
        "src/trpc/routers/users-admin.ts",
        "src/trpc/routers/bulk-operations.ts"
    ]
}
