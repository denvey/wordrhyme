{
    "name": "@wordrhyme/db",
    "version": "0.1.0-alpha.1",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./schema": {
            "types": "./dist/schema/index.d.ts",
            "import": "./dist/schema/index.js"
        },
        "./relations": {
            "types": "./dist/relations/index.d.ts",
            "import": "./dist/relations/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/types/index.js"
        },
        "./zod": {
            "types": "./src/zod/index.ts",
            "import": "./dist/zod/index.js"
        },
        "./plugin": {
            "types": "./src/plugin.ts",
            "import": "./src/plugin.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup && tsc --project tsconfig.dts.json --emitDeclarationOnly || true",
        "dev": "tsup --watch",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist tsconfig.tsbuildinfo"
    },
    "peerDependencies": {
        "drizzle-orm": ">=1.0.0-beta.1"
    },
    "devDependencies": {
        "drizzle-orm": "1.0.0-beta.14-a36c63d",
        "tsup": "^8.3.5",
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "drizzle-zod": "1.0.0-beta.14-a36c63d",
        "zod": "^4.3.6"
    }
}
