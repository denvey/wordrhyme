{
    "name": "@wordrhyme/server",
    "version": "0.1.0-alpha.1",
    "private": true,
    "type": "module",
    "exports": {
        "./trpc/router": "./src/trpc/router.ts",
        "./plugins/capabilities/data": "./src/plugins/capabilities/data.capability.ts"
    },
    "scripts": {
        "build": "nest build",
        "dev": "nest start --watch",
        "start": "node dist/main.js",
        "start:prod": "node dist/main.js",
        "lint": "eslint \"src/**/*.ts\"",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:permission": "vitest run src/__tests__/permission/",
        "test:permission:watch": "vitest src/__tests__/permission/",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:seed": "tsx src/db/seed.ts",
        "seed:auth": "tsx src/db/seed-auth.ts",
        "seed:roles": "tsx src/db/seed/seed-roles-backfill.ts",
        "seed:admin-permissions": "tsx src/db/seed/seed-admin-permissions.ts",
        "seed:test-accounts": "tsx src/db/seed/seed-test-accounts.ts",
        "seed:accounts": "tsx src/db/seed/seed-accounts.ts",
        "script:reset-dev": "tsx scripts/dev/reset-dev-database.ts",
        "script:seed-initial": "tsx scripts/seed/seed-initial-data.ts",
        "script:setup-cross-tenant": "tsx scripts/setup/setup-cross-tenant-permissions.ts"
    },
    "dependencies": {
        "@casl/ability": "^6.7.2",
        "@fastify/cors": "^9.0.1",
        "@fastify/multipart": "^9.4.0",
        "@fastify/static": "^8.0.4",
        "@nestjs/common": "^11.1.10",
        "@nestjs/core": "^11.1.10",
        "@nestjs/platform-fastify": "^11.1.10",
        "@nestjs/platform-socket.io": "^11.1.10",
        "@nestjs/schedule": "^6.1.0",
        "@nestjs/websockets": "^11.1.10",
        "@node-rs/argon2": "^2.0.2",
        "@thallesp/nestjs-better-auth": "^2.2.0",
        "@trpc/server": "^11.0.0-rc.660",
        "@wordrhyme/auto-crud-server": "^1.0.1",
        "@wordrhyme/db": "workspace:*",
        "@wordrhyme/plugin": "workspace:*",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "better-auth": "^1.4.9",
        "bullmq": "^5.34.8",
        "cron-parser": "^5.4.0",
        "decimal.js": "^10.4.3",
        "dotenv": "^17.2.3",
        "drizzle-orm": "1.0.0-beta.14-a36c63d",
        "drizzle-zod": "1.0.0-beta.14-a36c63d",
        "glob": "^11.0.0",
        "ioredis": "^5.4.2",
        "postgres": "^3.4.5",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@swc/cli": "^0.5.2",
        "@swc/core": "^1.10.7",
        "@types/node": "^22.10.2",
        "@vitest/coverage-v8": "^4.0.16",
        "drizzle-kit": "^0.31.8",
        "fastify": "^5.6.2",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "unplugin-swc": "^1.5.9",
        "vitest": "^4.0.16"
    }
}