{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": false
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "*.config.ts"
    ]
}
