# ============================================================
# WordRhyme Production Environment Variables
# Copy this file to .env.production and fill in real values
# ⚠️ NEVER commit .env.production to Git!
# ============================================================

# ---- Domains ----
SERVER_DOMAIN=api.your-domain.com
ADMIN_DOMAIN=admin.your-domain.com
WEB_DOMAIN=your-domain.com

# ---- Database ----
DB_USER=wordrhyme
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_1
DB_NAME=wordrhyme

# 单机模式: 上面 3 个就够了，compose 自动拼接本机连接串
# 外部数据库模式: 设置 DATABASE_URL 后，上面 3 个仅供备份脚本使用
# DATABASE_URL=postgresql://user:pass@db-server-ip:5432/wordrhyme?sslmode=require

# 独立数据库服务器额外配置 (单机模式不需要改):
# DB_PORT=5432
# DB_BIND_HOST=0.0.0.0

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_2

# 外部 Redis:
# REDIS_URL=redis://:password@redis-host:6379

# 独立数据库服务器额外配置 (单机模式不需要改):
# REDIS_PORT=6379
# REDIS_BIND_HOST=0.0.0.0

# ---- CORS ----
CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ---- App URL ----
APP_URL=https://api.your-domain.com

# ---- Admin Account ----
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_3
ADMIN_NAME=admin

# ---- Stripe (可选) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- 云存储备份 (可选) ----
# BACKUP_S3_ENDPOINT=https://oss-us-west-1.aliyuncs.com
# BACKUP_S3_BUCKET=wordrhyme-backups
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
