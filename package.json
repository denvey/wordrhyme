{
    "name": "wordrhyme",
    "version": "0.1.0-alpha.1",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "turbo run build --filter='./packages/*' && turbo run dev --filter=@wordrhyme/admin --filter=@wordrhyme/server --filter=@wordrhyme/web --concurrency=5",
        "dev:all": "turbo run dev --concurrency=26",
        "dev:pkg": "bash scripts/dev-pkg.sh",
        "dev:plugin": "bash scripts/dev-plugin.sh",
        "build": "turbo run build",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "lint:css": "stylelint \"**/*.css\" --ignore-path .gitignore",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "check": "biome check .",
        "type-check": "turbo run type-check",
        "test": "turbo run test",
        "clean": "turbo run clean && rm -rf node_modules",
        "db:generate": "pnpm --filter @wordrhyme/server db:generate",
        "db:migrate": "pnpm --filter @wordrhyme/server db:migrate",
        "db:seed": "pnpm --filter @wordrhyme/server db:seed",
        "db:setup": "pnpm --filter @wordrhyme/db build && pnpm db:generate && pnpm db:migrate && pnpm --filter @wordrhyme/server seed:accounts && pnpm db:seed",
        "test:spec": "tsx scripts/spec-test-runner.ts",
        "test:spec:list": "tsx scripts/spec-test-runner.ts --list",
        "test:spec:all": "tsx scripts/spec-test-runner.ts --all",
        "test:spec:approved": "tsx scripts/spec-test-runner.ts --approved"
    },
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@types/node": "^22.19.13",
        "stylelint": "^17.4.0",
        "stylelint-use-logical-spec": "^5.0.1",
        "tsx": "^4.21.0",
        "turbo": "^2.8.13",
        "typescript": "^5.9.3",
        "yaml": "^2.8.2"
    }
}