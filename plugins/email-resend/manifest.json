{
    "pluginId": "com.wordrhyme.email-resend",
    "version": "0.1.0",
    "name": "Resend Email",
    "description": "Send notification emails via Resend API",
    "vendor": "WordRhyme",
    "type": "full",
    "runtime": "node",
    "engines": {
        "wordrhyme": "^0.1.0",
        "node": ">=20.0.0"
    },
    "infrastructure": {
        "tenantOverride": true,
        "riskLevel": "medium",
        "sensitiveFields": ["apiKey"]
    },
    "capabilities": {
        "ui": {
            "adminPage": true,
            "settingsTab": true
        }
    },
    "permissions": {
        "definitions": [
            {
                "key": "settings.read",
                "description": "View email settings"
            },
            {
                "key": "settings.write",
                "description": "Modify email settings"
            },
            {
                "key": "test.send",
                "description": "Send test emails"
            }
        ]
    },
    "server": {
        "entry": "./dist/server/index.js",
        "hooks": ["onEnable", "onDisable"]
    },
    "admin": {
        "remoteEntry": "./dist/admin/remoteEntry.js",
        "exposes": {
            "./admin": "./src/admin/index.tsx"
        },
        "extensions": [
            {
                "id": "email-resend.main",
                "label": "Email (Resend)",
                "targets": [
                    {
                        "slot": "nav.sidebar",
                        "path": "/p/com.wordrhyme.email-resend",
                        "icon": "Mail",
                        "order": 50
                    },
                    {
                        "slot": "settings.plugin",
                        "order": 50
                    }
                ]
            }
        ]
    }
}
